# ============================================================
# Bank AI Call Engine - 环境变量配置模板
# ============================================================
# 使用说明:
# 1. 复制本文件为 .env
# 2. 填写必要的 API Key
# 3. 运行 docker-compose up -d 启动服务
# ============================================================

# ----------------------------------------
# LLM 配置（阿里云百炼）- 必填
# ----------------------------------------
# 申请地址：https://dashscope.console.aliyun.com/apiKey
LLM_API_KEY=sk-sp-xxxxxxxxxxxxxxxx

# LLM 提供商（默认：dashscope_coding）
# 可选值：dashscope_coding, dashscope, deepseek, openai
LLM_PROVIDER=dashscope_coding

# ----------------------------------------
# TTS 配置（火山引擎豆包）- 必填
# ----------------------------------------
# 火山引擎豆包访问令牌
DOUBAO_ACCESS_TOKEN=HthevSMrUFC7z8Nxfb0yKFyR1XVNeW-W

# 火山引擎豆包 APPID（默认：2058216235）
DOUBAO_APPID=2058216235

# ----------------------------------------
# ASR 配置（火山引擎豆包）- 选填
# ----------------------------------------
# ASR WebSocket 地址（默认：火山引擎豆包流式识别）
ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async

# ----------------------------------------
# 服务配置 - 选填
# ----------------------------------------
# 服务端口（默认：5001）
PORT=5001

# 服务地址（默认：0.0.0.0）
HOST=0.0.0.0

# ----------------------------------------
# 日志配置 - 选填
# ----------------------------------------
# 日志级别（默认：INFO）
LOG_LEVEL=INFO

# ----------------------------------------
# 通话配置 - 选填
# ----------------------------------------
# 最大通话时长（秒，默认：300）
MAX_DURATION=300

# 最大对话轮数（默认：10）
MAX_TURNS=10

# 静音超时（秒，默认：10.0）
SILENCE_TIMEOUT=10.0
